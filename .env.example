# open_claw platform — copy thành .env.secrets hoặc apps/telegram-bot/.env (KHÔNG commit)

# ─── GitHub ─────────────────────────────────────────────────────────
# Remote: github.com/<user>/open_claw

# ─── Railway (project: open_claw) ─────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# Service: openclaw-gateway — production (bắt buộc cho Railway)
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENCLAW_GATEWAY_TOKEN=
PORT=18789

# ─── Supabase (project: open_claw) ──────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── telegram-bot — local dev / optional Railway ─────────────────────
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
AI_PROVIDER=openclaw
OPENCLAW_BASE_URL=http://openclaw-gateway.railway.internal:18789/v1
OPENCLAW_AGENT_ID=default
OPENCLAW_TIMEOUT=90
OPENCLAW_VISION_TIMEOUT=180
GMAIL_USER=
GMAIL_APP_PASSWORD=
ECARGO_STORAGE_STATE=data/ecargo_storage.json
IMAGE_READER_ENABLED=true
SCALE_TICKET_OCR_ENABLED=true
MAIL_WATCH_ENABLED=false
ECARGO_DRY_RUN=true
ECARGO_DEFAULT_PCS=1
ECARGO_DEFAULT_GW=1.0
OPS_ENABLED=true
CHAT_ENABLED=true

# Không dùng OPENAI_API_KEY / DEEPSEEK_API_KEY trên production

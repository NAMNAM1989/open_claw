# open_claw platform — copy thành .env local (KHÔNG commit)

# ─── GitHub ─────────────────────────────────────────────────────────
# Remote: github.com/<user>/open_claw

# ─── Railway (project: open_claw) ─────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# Service: telegram-bot
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
GMAIL_USER=
GMAIL_APP_PASSWORD=
ECARGO_STORAGE_STATE=data/ecargo_storage.json
AI_PROVIDER=openclaw
OPENCLAW_BASE_URL=http://openclaw-gateway.railway.internal:18789/v1
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=default
OPENCLAW_TIMEOUT=90
OPENCLAW_VISION_TIMEOUT=180
OPENCLAW_CURSOR_ENABLED=false
USE_TAILSCALE=false

# Service: openclaw-gateway (LLM = Gemini only — xem docs/MODELS.md)
GEMINI_API_KEY=
GOOGLE_API_KEY=              # cùng giá trị GEMINI_API_KEY
PORT=18789
# Không dùng OPENAI_API_KEY / DEEPSEEK_API_KEY trên production

# ─── Supabase (project: open_claw) ──────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=   # không dùng trên bot production

# ─── Feature flags (telegram-bot) ─────────────────────────────────────
IMAGE_READER_ENABLED=true
SCALE_TICKET_OCR_ENABLED=true
MAIL_WATCH_ENABLED=false
ECARGO_DRY_RUN=true
ECARGO_DEFAULT_PCS=1
ECARGO_DEFAULT_GW=1.0
OPS_ENABLED=true
CHAT_ENABLED=true

# open_claw platform — copy thành .env.secrets (gitignored, KHÔNG commit)

# ─── GitHub ─────────────────────────────────────────────────────────
# Remote: github.com/<user>/open_claw

# ─── Railway (project: open_claw) ─────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# Service: openclaw-gateway — production
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENCLAW_GATEWAY_TOKEN=
PORT=18789

# ─── Supabase (project: open_claw) — tùy chọn, dùng khi tích hợp DB sau
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Không dùng OPENAI_API_KEY / DEEPSEEK_API_KEY trên production

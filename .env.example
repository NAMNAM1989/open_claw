# open_claw platform — copy thành .env.secrets (gitignored, KHÔNG commit)

# ─── Railway (project: open_claw) ─────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# openclaw-gateway
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=              # fallback cuối (platform.deepseek.com)
OPENAI_API_KEY=                # ChatGPT fallback (platform.openai.com)
OPENCLAW_GATEWAY_TOKEN=
PORT=18789

# telegram-bot (service open_claw — token từ BotFather)
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
OPENCLAW_BASE_URL=http://openclaw-gateway.railway.internal:18789/v1
VOLUMETRIC_DIVISOR=6000

# Supabase (tùy chọn)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vietnam legal research PoC (plugin vietnam-legal-research) — KHÔNG commit credential thật
# Default link-only: chỉ tạo URL tra cứu, không scrape thuvienphapluat.vn
TVPL_INTEGRATION_MODE=link-only
TVPL_REQUESTS_PER_MINUTE=5
TVPL_CACHE_TTL_SECONDS=21600
TVPL_ALLOW_BROWSER=false
TVPL_USERNAME=
TVPL_PASSWORD=
TVPL_SESSION_STORAGE_PATH=
RUN_TVPL_LIVE_TESTS=false